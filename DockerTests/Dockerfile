# 1. Базовый образ Linux, на котором уже установлены Java 21 и Maven.
FROM maven:3.9-eclipse-temurin-21

# 2. Рабочая директория. Внутри контейнера создаем папку /app и переходим в нее.
WORKDIR /app

# 3. Кэширование
COPY pom.xml .
COPY testng.xml .

# Скачиваем все библиотеки из интернета.
# Docker запомнит этот шаг. Если pom.xml не менялся, он не будет качать их заново при следующем билде.
RUN mvn dependency:go-offline

# 4. Копируем исходный код тестов
COPY src ./src

# 5. Команда, которая выполнится при старте контейнера
CMD ["mvn", "test"]